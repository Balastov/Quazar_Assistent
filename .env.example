# Database
DATABASE_URL=postgresql+asyncpg://quazar:quazar@localhost:5432/quazar
DATABASE_URL_SYNC=postgresql://quazar:quazar@localhost:5432/quazar

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=quazar
MINIO_SECRET_KEY=quazarsecret
MINIO_BUCKET=quazar-files
MINIO_SECURE=false

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# LLM providers (configure per deployment)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Document ingestion
OCR_LANGUAGE=rus+eng
INGEST_VISION_FALLBACK=true
INGEST_VISION_MODEL=gpt-4o-mini
MPXJ_JAR_PATH=/app/lib/mpxj.jar

# App
API_HOST=0.0.0.0
API_PORT=8000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Public URL of API as seen from the browser (VM IP or domain, with port if needed)
# Example on server: PUBLIC_API_URL=http://203.0.113.10:8000
PUBLIC_API_URL=http://localhost:8000

# Encryption for stored API keys
SECRETS_ENCRYPTION_KEY=change-me-32-byte-key-here!!!!

# OIDC (optional, phase 3)
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
